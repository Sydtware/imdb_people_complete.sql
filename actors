-- Delete the old table (if it exists)
DROP TABLE IF EXISTS imdb_people;

-- 1. CREATE TABLE
CREATE TABLE imdb_people (
  nconst TEXT PRIMARY KEY,
  primaryName TEXT,
  birthYear INTEGER,
  deathYear INTEGER,
  primaryProfession TEXT,
  knownForTitles TEXT
);

